# =============== ICMP ===============

#  alert icmp any any <> any any (msg:"ICMP Ping"; sid:1000001; rev:2;)
# alert icmp $HOME_NET any -> $EXTERNAL_NET any (msg:"Outbound ICMP"; sid:1000002; rev:1;)
# alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"Inbound ICMP"; sid:1000003; rev:1;)

# --- ICMP ping flood  ---
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICMP flood detected"; sid:1000004; rev:1; threshold:type threshold, track by_src, count 40, seconds 60;)

# --- ICMP Network Sweep --- 
alert icmp any any -> $HOME_NET any ( msg:"ICMP Network Sweep"; itype:8; detection_filter:track by_src, count 15, seconds 30; sid:1000005; rev:1;)

# --- Oversized ICMP Packet ---
alert icmp any any -> $HOME_NET any ( msg:"Oversized ICMP Packet Detected"; dsize:>800; sid:1000006; rev:1;)

# --- Potential ICMP Tunn ---
alert icmp any any -> $HOME_NET any ( msg:"Potential ICMP Tunnel Large Payload"; itype:8; dsize:>800; detection_filter:track by_src, count 5, seconds 30; sid:1000007; rev:1;)


# =============== NMAP ===============

# --- Detect TCP SYN scan (typical Nmap -sS) ---
alert tcp $EXTERNAL_NET any -> $HOME_NET $COMMON_PORTS ( msg:"TCP SYN Scan Detected"; flow:stateless; priority:3; flags:S,12; detection_filter:track by_src, count 20, seconds 5; sid:3000001; rev:1;)

# --- Detect XMAS scan (Nmap -sX) — FIN, PUSH, URG flags set (FPU) ---
alert tcp any any -> $HOME_NET $COMMON_PORTS (msg:"Detection - XMAS Scan"; flags:FPU;  priority:3; detection_filter:track by_src, count 30, seconds 60; sid:10000012; rev:1;)

# --- Detect FIN Scan (Nmap -sF) ---
alert tcp any any -> $HOME_NET $COMMON_PORTS (msg:"Detection - FIN Scan"; flags:F;  priority:3; detection_filter:track by_src, count 30, seconds 60; sid:10000013; rev:1;)

# --- Detect NULL scan (Nmap -sN) — no flags set ---
alert tcp any any -> $HOME_NET $COMMON_PORTS (msg:"Detection - NULL Scan"; flags:0;  priority:3; detection_filter:track by_src, count 30, seconds 60; sid:10000014; rev:1;)

# --- Detect UDP scan (Nmap -sU) ---
alert udp any any -> $HOME_NET $COMMON_PORTS (msg:"Detection - UDP Scan";  priority:3; threshold:type limit, track by_src, count 30, seconds 60; sid:10000015; rev:1;)



# =============== SSH brute force  ===============

alert tcp any any -> $HOME_NET 22 (msg:"Possible SSH Brute Force"; flow:to_server,established; content:"SSH-"; detection_filter:track by_src, count 5, seconds 60; priority:1; sid:1000020; rev:1;)



# =============== RDP brute force ===============

alert tcp any any -> $HOME_NET 3389 (msg: "Possible RDP Brute Force"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; detection_filter:track by_src, count 5, seconds 60;  priority:1; sid:10000031; rev:1;)



# =============== FTP brute force ===============

alert tcp $HOME_NET 21 -> $EXTERNAL_NET any ( msg:"FTP Brute Force - Auth Failure"; flow:from_server,established; content:"530 "; offset:0; depth:4; detection_filter:track by_dst, count 5, seconds 60; priority:2; sid:10000041; rev:1; )
alert tcp  $EXTERNAL_NET any -> $HOME_NET 21 ( msg:"FTP Anonymous Login Attempt"; flow:from_server,established; content:"USER anonymous"; nocase; priority:2; sid:10000041; rev:1; )


# =============== web ===============

alert tcp any any -> $HOME_NET 80 (msg:"SQLi UNION SELECT in URI"; flow:to_server,established; content:"UNION"; nocase; http_uri; pcre:"/union\s+(all\s+)?select/Ui"; priority:1; sid:9000051; rev:1;)
alert tcp any any -> $HOME_NET 80 ( msg:"XSS script tag in URI"; flow:to_server,established; content:"<script"; nocase; http_uri; pcre:"/(%3C|<)\s*script/Ui"; priority:1; sid:9000054; rev:2;)


